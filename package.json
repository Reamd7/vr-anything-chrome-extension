{
  "name": "web-vr-extension",
  "displayName": "Web VR Player",
  "version": "0.1.0",
  "description": "Browser extension that turns any <video> element into VR playback mode using Three.js",
  "author": "wuyuan",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.0",
    "typescript": "^5.6.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "scripting"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
